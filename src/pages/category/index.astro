---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { SITE_TITLE } from "@consts";

const posts = await getCollection("posts");

const stats = new Map<string, { count: number; latest: Date }>();
for (const post of posts) {
  const cat = post.data.category;
  if (!cat) continue;
  const d = post.data.pubDate;
  const cur = stats.get(cat);
  if (!cur) stats.set(cat, { count: 1, latest: d });
  else {
    cur.count += 1;
    if (d > cur.latest) cur.latest = d;
  }
}

const categories = [...stats.entries()]
  .map(([name, s]) => ({ name, count: s.count, latest: s.latest }))
  .sort((a, b) => b.count - a.count);

const ICONS: Record<string, string> = {
  dev: "icon-[tabler--code]",
  Life: "icon-[tabler--heart]",
  MYCTF: "icon-[tabler--flag]",
  Network: "icon-[tabler--world]",
};
const iconFor = (name: string) => ICONS[name] ?? "icon-[tabler--folder]";
---

<BaseLayout title={`Folder - ${SITE_TITLE}`} description="瀏覽所有文章分類">
  <section class="folder-header">
    <h1 class="folder-title brand-mark">/ Folder /</h1>
    <p class="folder-sub">
      目前累積 <span class="accent-num">{categories.length}</span> 個分類
    </p>
    <div class="folder-rule"></div>
  </section>

  {
    categories.length > 0 ? (
      <div class="cat-grid">
        {categories.map((cat) => (
          <a href={`/category/${encodeURIComponent(cat.name)}/1/`} class="cat-card">
            <div class="cat-top">
              <i class={`cat-icon ${iconFor(cat.name)}`} />
              <span class="cat-badge">{cat.count}</span>
            </div>
            <h2 class="cat-name">{cat.name}</h2>
            <p class="cat-meta">{cat.count} 篇文章</p>
            <span class="cat-arrow">→</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="folder-empty">尚無分類</p>
    )
  }
</BaseLayout>

<style>
  .folder-header {
    text-align: center;
    margin: clamp(1.5rem, 5vw, 3rem) 0 clamp(2rem, 5vw, 3rem);
  }
  .folder-title {
    font-size: clamp(1.8rem, 7vw, 2.8rem);
    font-weight: 700;
    color: rgb(var(--black));
    margin: 0;
    letter-spacing: -0.04em;
  }
  .folder-sub {
    color: rgb(var(--text-muted));
    font-family: var(--font-brand);
    margin: 1rem 0 0;
  }
  .accent-num {
    color: var(--accent);
    font-weight: 700;
  }
  .folder-rule {
    width: 80px;
    height: 3px;
    background: var(--accent);
    margin: 1.75rem auto 0;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }

  .cat-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: rgba(var(--bg-card), 0.7);
    border: 1px solid rgba(var(--border), 0.3);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }
  .cat-card:hover {
    border-color: rgba(var(--accent-rgb), 0.5);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
    transform: translateY(-3px);
  }

  .cat-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .cat-icon {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--accent);
    transition: transform 0.25s ease;
  }
  .cat-card:hover .cat-icon {
    transform: scale(1.12);
  }
  .cat-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    height: 1.75rem;
    padding: 0 0.5rem;
    background: rgba(var(--accent-rgb), 0.12);
    color: var(--accent);
    border: 1px solid rgba(var(--accent-rgb), 0.25);
    font-size: 0.72rem;
    font-weight: 700;
    font-family: var(--font-brand);
  }

  .cat-name {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    color: rgb(var(--black));
    margin: 0 0 0.35rem;
    line-height: 1.3;
    transition: color 0.25s ease;
  }
  .cat-card:hover .cat-name {
    color: var(--accent);
  }
  .cat-meta {
    font-size: 0.78rem;
    color: rgb(var(--text-muted));
    margin: 0;
    font-family: var(--font-brand);
  }

  .cat-arrow {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(var(--border), 0.2);
    font-size: 0.9rem;
    color: rgb(var(--text-muted));
    text-align: right;
    transition:
      color 0.25s ease,
      transform 0.25s ease;
  }
  .cat-card:hover .cat-arrow {
    color: var(--accent);
  }

  .folder-empty {
    text-align: center;
    color: rgb(var(--text-muted));
    font-family: var(--font-brand);
    padding: 3rem 0;
  }

  @media (max-width: 900px) {
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
