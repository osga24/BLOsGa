---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import "../styles/global.css";
import Squares from '../components/Squares.astro';
import TypeWirte from '../components/TypeWrite.astro';
import { ViewTransitions } from 'astro:transitions';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const talksomething = [
	"每個成功的男人背後，都有一條脊椎",
	"我一拳把自己打死了，算強壯還是虛弱",
	"如果你願意多花一點時間了解我，你會發現多花了一點時間",
	"過期的毒藥是更毒還是不毒",
	"吃麻婆豆腐會不會被麻婆告",
	"你知道你在吹電風扇時其實是電風扇在吹你嗎",
	"咖啡算不算一種豆漿",
	"坐電梯其實是站電梯",
	"剛睡醒的時候就像剛睡醒的時候一樣，有一種剛睡醒的感覺。如果你也是剛睡醒，那麼你也剛睡醒"
];

const featuredPost = posts[0];
const heroPost    = posts[1];
const secondPost  = posts[2];
const gridPosts   = posts.slice(3);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<ViewTransitions/>
	</head>
	<body>
		<Header />

		<!-- ── Hero Section ── -->
		<section class="hero-section">
			<div class="hero-background">
				<Squares
					direction="diagonal"
					speed={0.5}
					squareSize={30}
					borderColor="rgba(90, 128, 113, 0.15)"
					hoverFillColor="rgba(90, 128, 113, 0.1)"
					opacity={0.3}
					class="hero-squares"
				/>
			</div>
			<div class="hero-content">
				<h1 class="gradient-text">/ {SITE_TITLE} /</h1>
				<p class="hero-description">
					<TypeWirte
						words={talksomething}
						speed={100}
						deleteSpeed={80}
						pauseTime={3000}>
				</p>
				<div class="hero-divider"></div>
				<div class="social-icons">
					<a href="https://github.com/osga24/blosga" target="_blank" class="social-link" aria-label="GitHub">
						<svg viewBox="0 0 16 16" width="20" height="20">
							<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
						</svg>
					</a>
					<a href="https://osga.dev" target="_blank" class="social-link" aria-label="osga.dev">
						<svg viewBox="0 0 16 16" width="20" height="20">
							<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zM6.5 4.5c0-.28.22-.5.5-.5s.5.22.5.5-.22.5-.5.5-.5-.22-.5-.5zm3 0c0-.28.22-.5.5-.5s.5.22.5.5-.22.5-.5.5-.5-.22-.5-.5zM8 13c-2.76 0-5-2.24-5-5 0-.55.45-1 1-1s1 .45 1 1c0 1.65 1.35 3 3 3s3-1.35 3-3c0-.55.45-1 1-1s1 .45 1 1c0 2.76-2.24 5-5 5z"/>
						</svg>
					</a>
				</div>
			</div>
		</section>

		<main>
			{posts.length === 0 ? (
				<div class="empty-state">
					<div class="empty-icon">📝</div>
					<h3>還沒有文章</h3>
					<p>開始寫你的第一篇文章吧！</p>
				</div>
			) : (
				<>
					<!-- ── Featured Post ── -->
					{featuredPost && (
						<section class="section-block">
							<div class="section-header">
								<span class="section-label">Featured</span>
							</div>
							<a href={`/blog/${featuredPost.slug}/`} class="featured-link">
								<article class="featured-post">
									{featuredPost.data.heroImage && (
										<div class="featured-img-wrap">
											<img
												class="featured-img"
												src={featuredPost.data.heroImage.src}
												width={featuredPost.data.heroImage.width}
												height={featuredPost.data.heroImage.height}
												alt={featuredPost.data.title}
												loading="eager"
												decoding="async"
											/>
										</div>
									)}
									<div class="featured-body">
										{featuredPost.data.category && (
											<span class="tag-chip">{featuredPost.data.category}</span>
										)}
										<h2 class="featured-title">{featuredPost.data.title}</h2>
										{featuredPost.data.description && (
											<p class="featured-desc">{featuredPost.data.description}</p>
										)}
										<div class="card-footer">
											<div class="tag-row">
												{featuredPost.data.tags && featuredPost.data.tags.slice(0, 3).map(tag => (
													<span class="tag-dot">#{tag}</span>
												))}
											</div>
											<time class="card-date">
												<FormattedDate date={featuredPost.data.pubDate} />
											</time>
										</div>
									</div>
								</article>
							</a>
						</section>
					)}

					<!-- ── Latest Posts ── -->
					{posts.length > 1 && (
						<section class="section-block">
							<div class="section-header">
								<span class="section-label">Latest</span>
							</div>

							<!-- Top 2 large cards -->
							{(heroPost || secondPost) && (
								<div class="large-grid">
									{[heroPost, secondPost].filter(Boolean).map((post) => (
										<a href={`/blog/${post.slug}/`} class="pcard-link">
											<article class="pcard pcard--large">
												{post.data.heroImage && (
													<div class="pcard-img-wrap">
														<img
															class="pcard-img"
															src={post.data.heroImage.src}
															width={post.data.heroImage.width}
															height={post.data.heroImage.height}
															alt={post.data.title}
															loading="lazy"
															decoding="async"
														/>
													</div>
												)}
												<div class="pcard-body">
													<div class="pcard-meta-top">
														{post.data.category && (
															<span class="tag-chip">{post.data.category}</span>
														)}
														<time class="card-date">
															<FormattedDate date={post.data.pubDate} />
														</time>
													</div>
													<h3 class="pcard-title">{post.data.title}</h3>
													{post.data.description && (
														<p class="pcard-desc">{post.data.description}</p>
													)}
													{post.data.tags && post.data.tags.length > 0 && (
														<div class="tag-row pcard-tags">
															{post.data.tags.slice(0, 4).map(tag => (
																<span class="tag-dot">#{tag}</span>
															))}
														</div>
													)}
												</div>
											</article>
										</a>
									))}
								</div>
							)}

							<!-- Small cards grid -->
							{gridPosts.length > 0 && (
								<div class="small-grid">
									{gridPosts.map((post) => (
										<a href={`/blog/${post.slug}/`} class="pcard-link">
											<article class="pcard pcard--small">
												{post.data.heroImage && (
													<div class="pcard-img-wrap">
														<img
															class="pcard-img"
															src={post.data.heroImage.src}
															width={post.data.heroImage.width}
															height={post.data.heroImage.height}
															alt={post.data.title}
															loading="lazy"
															decoding="async"
														/>
													</div>
												)}
												<div class="pcard-body">
													<div class="pcard-meta-top">
														{post.data.category && (
															<span class="tag-chip">{post.data.category}</span>
														)}
														<time class="card-date">
															<FormattedDate date={post.data.pubDate} />
														</time>
													</div>
													<h3 class="pcard-title">{post.data.title}</h3>
													{post.data.description && (
														<p class="pcard-desc pcard-desc--clamp">{post.data.description}</p>
													)}
													{post.data.tags && post.data.tags.length > 0 && (
														<div class="tag-row pcard-tags">
															{post.data.tags.slice(0, 3).map(tag => (
																<span class="tag-dot">#{tag}</span>
															))}
															{post.data.tags.length > 3 && (
																<span class="tag-dot tag-more">+{post.data.tags.length - 3}</span>
															)}
														</div>
													)}
												</div>
											</article>
										</a>
									))}
								</div>
							)}
						</section>
					)}
				</>
			)}
		</main>

		<Footer />
	</body>
</html>

<style>
/* ══════════════════════════════════
   Hero Section
══════════════════════════════════ */
.hero-section {
	max-width: calc(100% - 1.5em);
	margin: 1.5em 1.5em 4rem;
	position: relative;
	border-radius: 20px;
	overflow: hidden;
	border: 1px solid rgba(var(--border), 0.2);
}
.hero-background {
	position: absolute;
	inset: 0;
	z-index: 1;
}
.hero-content {
	position: relative;
	z-index: 2;
	text-align: center;
	padding: 4rem 2rem;
}
.social-icons {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 1rem;
	margin-top: 2rem;
}
.social-link {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 44px;
	height: 44px;
	color: rgb(var(--gray));
	text-decoration: none;
	border-radius: 12px;
	transition: all 0.3s ease;
	background: rgba(var(--bg-card), 0.3);
	border: 1px solid rgba(var(--border), 0.1);
}
.social-link:hover {
	color: var(--accent);
	background: rgba(var(--bg-hover), 0.6);
	border-color: rgba(var(--accent), 0.3);
	transform: translateY(-2px);
	box-shadow: 0 4px 12px rgba(var(--accent), 0.2);
}
.social-link svg { transition: transform 0.3s ease; }
.social-link:hover svg { transform: scale(1.1); }

/* ══════════════════════════════════
   Section Header
══════════════════════════════════ */
.section-block { margin-bottom: clamp(2rem, 5vw, 3.5rem); }
.section-header {
	display: flex;
	align-items: center;
	gap: 1rem;
	margin-bottom: 1.5rem;
}
.section-header::after {
	content: '';
	flex: 1;
	height: 1px;
	background: rgba(var(--border), 0.3);
}
.section-label {
	font-size: 0.7rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.14em;
	color: var(--accent);
}

/* ══════════════════════════════════
   Featured Post
══════════════════════════════════ */
.featured-link {
	display: block;
	text-decoration: none;
	color: inherit;
}
.featured-link:hover { opacity: 1; }

.featured-post {
	display: grid;
	grid-template-columns: 58% 42%;
	background: rgba(var(--bg-card), 0.8);
	backdrop-filter: blur(10px);
	border: 1px solid rgba(var(--border), 0.3);
	border-radius: 16px;
	overflow: hidden;
	transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
}
.featured-link:hover .featured-post {
	border-color: rgba(var(--accent), 0.5);
	box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
	transform: translateY(-2px);
}

.featured-img-wrap {
	overflow: hidden;
	aspect-ratio: 3 / 2;
}
.featured-img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	border-radius: 0;
	transition: transform 0.5s ease;
}
.featured-link:hover .featured-img { transform: scale(1.05); }

.featured-body {
	padding: clamp(1.5rem, 3vw, 2.5rem);
	display: flex;
	flex-direction: column;
	border-left: 1px solid rgba(var(--border), 0.2);
}

.featured-title {
	font-size: clamp(1.25rem, 2.8vw, 1.9rem);
	font-weight: 700;
	color: rgb(var(--black));
	line-height: 1.25;
	margin: 0.75rem 0 0.875rem;
	transition: color 0.3s ease;
}
.featured-link:hover .featured-title { color: var(--accent); }

.featured-desc {
	color: rgb(var(--gray));
	font-size: 0.9rem;
	line-height: 1.65;
	flex: 1;
	margin: 0;
}

.card-footer {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 0.75rem;
	padding-top: 1rem;
	border-top: 1px solid rgba(var(--border), 0.2);
	margin-top: 1.25rem;
}

/* ══════════════════════════════════
   Post Card  (large + small)
══════════════════════════════════ */
.pcard-link {
	display: block;
	text-decoration: none;
	color: inherit;
}
.pcard-link:hover { opacity: 1; }

.pcard {
	display: flex;
	flex-direction: column;
	height: 100%;
	background: rgba(var(--bg-card), 0.8);
	backdrop-filter: blur(10px);
	border: 1px solid rgba(var(--border), 0.3);
	border-radius: 14px;
	overflow: hidden;
	transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
}
.pcard::before {
	content: '';
	position: absolute;
	top: 0; left: 0; right: 0;
	height: 1px;
	background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
}
.pcard { position: relative; }

.pcard-link:hover .pcard {
	border-color: rgba(var(--accent), 0.45);
	box-shadow: 0 8px 28px rgba(0, 0, 0, 0.28);
	transform: translateY(-3px);
}

/* Image */
.pcard-img-wrap {
	overflow: hidden;
	aspect-ratio: 16 / 9;
	flex-shrink: 0;
}
.pcard-img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	border-radius: 0;
	transition: transform 0.45s ease;
}
.pcard-link:hover .pcard-img { transform: scale(1.05); }

/* Body */
.pcard-body {
	flex: 1;
	display: flex;
	flex-direction: column;
	padding: 1.1rem 1.25rem 1.25rem;
}

.pcard-meta-top {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 0.5rem;
	margin-bottom: 0.6rem;
}

.pcard-title {
	color: rgb(var(--black));
	font-weight: 700;
	line-height: 1.3;
	margin: 0 0 0.6rem;
	transition: color 0.3s ease;
}
.pcard--large .pcard-title { font-size: clamp(1.05rem, 2vw, 1.35rem); }
.pcard--small .pcard-title  { font-size: clamp(0.95rem, 1.8vw, 1.1rem); }
.pcard-link:hover .pcard-title { color: var(--accent); }

.pcard-desc {
	color: rgb(var(--gray));
	font-size: 0.875rem;
	line-height: 1.6;
	flex: 1;
	margin: 0;
}
.pcard-desc--clamp {
	display: -webkit-box;
	-webkit-line-clamp: 3;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.pcard-tags {
	margin-top: 0.875rem;
	padding-top: 0.75rem;
	border-top: 1px solid rgba(var(--border), 0.2);
}

/* ══════════════════════════════════
   Shared: Chips, Tags, Date
══════════════════════════════════ */
.tag-chip {
	display: inline-block;
	padding: 0.22rem 0.6rem;
	background: rgba(var(--accent), 0.12);
	color: var(--accent);
	border: 1px solid rgba(var(--accent), 0.25);
	border-radius: 6px;
	font-size: 0.65rem;
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	white-space: nowrap;
	flex-shrink: 0;
}

.card-date {
	font-size: 0.7rem;
	color: rgb(var(--text-muted));
	white-space: nowrap;
	letter-spacing: 0.02em;
}

.tag-row {
	display: flex;
	flex-wrap: wrap;
	gap: 0.4rem;
	align-items: center;
}
.tag-dot {
	font-size: 0.68rem;
	color: rgb(var(--text-muted));
	font-weight: 400;
}
.tag-more { opacity: 0.6; }

/* ══════════════════════════════════
   Grids
══════════════════════════════════ */
.large-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: clamp(1rem, 2.5vw, 1.75rem);
	margin-bottom: clamp(1rem, 2.5vw, 1.75rem);
}

.small-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: clamp(1rem, 2.5vw, 1.75rem);
}

/* ══════════════════════════════════
   Responsive
══════════════════════════════════ */
@media (max-width: 900px) {
	.small-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
	.hero-content { padding: 2rem 1rem; }
	.social-icons { gap: 0.75rem; }
	.social-link { width: 40px; height: 40px; }

	.featured-post { grid-template-columns: 1fr; }
	.featured-img-wrap { aspect-ratio: 16 / 9; }
	.featured-body {
		border-left: none;
		border-top: 1px solid rgba(var(--border), 0.2);
	}
	.large-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
	.small-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
	.social-link { width: 36px; height: 36px; }
}
</style>
