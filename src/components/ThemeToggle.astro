---
// Theme toggle cycling: light → dark → system.
// "system" follows the OS prefers-color-scheme and updates live.
// Persists the chosen mode (not the resolved theme) to localStorage["theme"].
---

<button type="button" class="theme-toggle" data-theme-toggle aria-label="切換主題">
  <i class="theme-icon ti-sun icon-[tabler--sun-filled]"></i>
  <i class="theme-icon ti-moon icon-[tabler--moon-filled]"></i>
  <i class="theme-icon ti-system icon-[tabler--device-desktop]"></i>
</button>

<script>
  const root = document.documentElement;
  const MODES = ["light", "dark", "system"] as const;
  type Mode = (typeof MODES)[number];
  const mql = window.matchMedia("(prefers-color-scheme: dark)");

  const systemTheme = () => (mql.matches ? "dark" : "light");

  function getMode(): Mode {
    try {
      const m = localStorage.getItem("theme");
      return (MODES as readonly string[]).includes(m ?? "") ? (m as Mode) : "system";
    } catch {
      return "system";
    }
  }

  function applyMode(mode: Mode) {
    root.dataset.themeMode = mode;
    root.dataset.theme = mode === "system" ? systemTheme() : mode;
    try {
      localStorage.setItem("theme", mode);
    } catch {}
  }

  // Keep "system" mode in sync with live OS changes.
  mql.addEventListener("change", () => {
    if (getMode() === "system") root.dataset.theme = systemTheme();
  });

  function bind() {
    const button = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
    if (!button || (button as any)._bound) return;
    (button as any)._bound = true;

    const motion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const doc = document as Document & {
      startViewTransition?: (cb: () => void) => {
        ready: Promise<void>;
        finished: Promise<void>;
      };
    };

    button.addEventListener("click", () => {
      const next = MODES[(MODES.indexOf(getMode()) + 1) % MODES.length];

      if (!doc.startViewTransition || motion.matches) {
        applyMode(next);
        return;
      }

      const rect = button.getBoundingClientRect();
      const x = rect.left + rect.width / 2;
      const y = rect.top + rect.height / 2;
      const end = Math.hypot(
        Math.max(x, window.innerWidth - x),
        Math.max(y, window.innerHeight - y),
      );

      root.setAttribute("data-theme-transition", "");
      const transition = doc.startViewTransition(() => applyMode(next));
      transition.ready.then(() => {
        root.animate(
          {
            clipPath: [
              `circle(0px at ${x}px ${y}px)`,
              `circle(${end}px at ${x}px ${y}px)`,
            ],
          },
          {
            duration: 520,
            easing: "cubic-bezier(0.2, 0.65, 0.3, 0.9)",
            pseudoElement: "::view-transition-new(root)",
          },
        );
      });
      transition.finished.finally(() => {
        root.removeAttribute("data-theme-transition");
      });
    });
  }

  bind();
  document.addEventListener("astro:page-load", bind);
</script>

<style>
  .theme-toggle {
    position: relative;
    appearance: none;
    border: 1px solid rgba(var(--border), 0.35);
    background: rgba(var(--bg-card), 0.4);
    color: rgb(var(--gray));
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      color 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease,
      transform 0.2s ease;
  }

  .theme-toggle:hover {
    color: var(--accent);
    border-color: rgba(var(--accent-rgb), 0.45);
    transform: scale(1.06);
  }

  .theme-icon {
    position: absolute;
    width: 1.05rem;
    height: 1.05rem;
    opacity: 0;
    transform: scale(0.6) rotate(-45deg);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  :global([data-theme-mode="light"]) .ti-sun,
  :global(:root:not([data-theme-mode])) .ti-sun {
    opacity: 1;
    transform: scale(1) rotate(0);
  }
  :global([data-theme-mode="dark"]) .ti-moon {
    opacity: 1;
    transform: scale(1) rotate(0);
  }
  :global([data-theme-mode="system"]) .ti-system {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle,
    .theme-icon {
      transition: none;
    }
  }
</style>
