---
import { SITE_TITLE } from '../consts';

interface Props {
  searchData: Array<{
    slug: string;
    title: string;
    description: string;
    category: string;
    tags: string[];
    date: string;
  }>;
}

const { searchData } = Astro.props;
---

<!-- Trigger (sits in nav flow) -->
<button class="s-trigger" id="s-trigger" aria-label="搜尋文章">
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
</button>

<!-- Backdrop — closes search on tap/click outside -->
<div class="s-backdrop" id="s-backdrop"></div>

<!-- Search layer -->
<div class="s-layer" id="s-layer" aria-hidden="true">

  <!-- Bar -->
  <div class="s-bar">
    <!-- Desktop: back arrow -->
    <button class="s-back" id="s-back" aria-label="關閉搜尋">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
      </svg>
    </button>
    <!-- Mobile: brand title (with padding, acts as home link) -->
    <a href="/" class="s-brand" aria-label="回首頁">{SITE_TITLE}</a>

    <div class="s-input-wrap">
      <svg class="s-icon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="s-input"
        class="s-input"
        type="text"
        placeholder="搜尋文章、分類、標籤…"
        autocomplete="off"
        spellcheck="false"
      />
      <button class="s-clear" id="s-clear" aria-label="清除">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Dropdown (extends below header) -->
  <div class="s-dropdown" id="s-dropdown">
    <div id="s-results" class="s-results" role="listbox"></div>
    <div class="s-footer">
      <span class="s-hint"><kbd>↑</kbd><kbd>↓</kbd> 導航</span>
      <span class="s-hint"><kbd>↵</kbd> 開啟</span>
      <span class="s-hint"><kbd>ESC</kbd> 關閉</span>
      <span class="s-count" id="s-count"></span>
    </div>
  </div>

</div>

<script define:vars={{ searchData }}>
  const trigger  = document.getElementById('s-trigger');
  const layer    = document.getElementById('s-layer');
  const backdrop = document.getElementById('s-backdrop');
  const backBtn  = document.getElementById('s-back');
  const input    = document.getElementById('s-input');
  const clearBtn = document.getElementById('s-clear');
  const results  = document.getElementById('s-results');
  const countEl  = document.getElementById('s-count');

  let activeIdx = -1;
  let opened = false;

  /* ── open / close ── */
  function open() {
    opened = true;
    layer.setAttribute('aria-hidden', 'false');
    layer.classList.add('is-open');
    backdrop.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    input.value = '';
    clearBtn.style.display = 'none';
    renderResults(searchData);
    setTimeout(() => input.focus(), 50);
  }

  function close() {
    opened = false;
    layer.setAttribute('aria-hidden', 'true');
    layer.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    document.body.style.overflow = '';
    activeIdx = -1;
  }

  trigger?.addEventListener('click', open);
  backBtn?.addEventListener('click', close);
  backdrop?.addEventListener('click', close);

  /* ── keyboard ── */
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      opened ? close() : open();
      return;
    }
    if (!opened) return;
    if (e.key === 'Escape')    { close(); return; }
    if (e.key === 'ArrowDown') { e.preventDefault(); move(1); return; }
    if (e.key === 'ArrowUp')   { e.preventDefault(); move(-1); return; }
    if (e.key === 'Enter') {
      const active = results.querySelector('.result-item.is-active');
      if (active) active.click();
    }
  });

  /* ── navigation ── */
  function move(dir) {
    const items = results.querySelectorAll('.result-item');
    if (!items.length) return;
    activeIdx = Math.max(0, Math.min(activeIdx + dir, items.length - 1));
    items.forEach((el, i) => el.classList.toggle('is-active', i === activeIdx));
    items[activeIdx]?.scrollIntoView({ block: 'nearest' });
  }

  /* ── search logic ── */
  function norm(s) { return s.toLowerCase().trim(); }

  function doSearch(q) {
    if (!q) return searchData;
    const nq = norm(q);
    return searchData.filter(p =>
      norm(p.title).includes(nq) ||
      norm(p.description).includes(nq) ||
      norm(p.category).includes(nq) ||
      p.tags.some(t => norm(t).includes(nq))
    );
  }

  function hl(text, q) {
    if (!q) return text;
    const esc = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return text.replace(new RegExp(`(${esc})`, 'gi'), '<mark>$1</mark>');
  }

  /* ── render ── */
  function renderResults(items) {
    activeIdx = -1;
    const q = input.value.trim();

    if (!items.length) {
      results.innerHTML = q
        ? `<p class="s-empty">找不到「${q}」相關的文章</p>`
        : '';
      countEl.textContent = '';
      return;
    }

    countEl.textContent = `${items.length} 篇`;
    results.innerHTML = items.map((post, i) => `
      <a href="/blog/${post.slug}/" class="result-item" role="option" data-index="${i}">
        <div class="result-body">
          <span class="result-title">${hl(post.title, q)}</span>
          ${post.description ? `<span class="result-desc">${hl(post.description, q)}</span>` : ''}
        </div>
        <div class="result-aside">
          ${post.category ? `<span class="result-chip">${hl(post.category, q)}</span>` : ''}
          <span class="result-date">${post.date}</span>
        </div>
      </a>
    `).join('');

    results.querySelectorAll('.result-item').forEach((el) => {
      el.addEventListener('click', close);
      el.addEventListener('mouseenter', () => {
        activeIdx = parseInt(el.dataset.index);
        results.querySelectorAll('.result-item')
          .forEach((r, i) => r.classList.toggle('is-active', i === activeIdx));
      });
    });
  }

  /* ── input events ── */
  input?.addEventListener('input', () => {
    const q = input.value.trim();
    clearBtn.style.display = q ? 'flex' : 'none';
    renderResults(doSearch(q));
  });

  clearBtn?.addEventListener('click', () => {
    input.value = '';
    clearBtn.style.display = 'none';
    renderResults(searchData);
    input.focus();
  });

  document.addEventListener('astro:before-swap', () => { if (opened) close(); });
</script>

<style>
/* ── Trigger ── */
.s-trigger {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  flex-shrink: 0;
  background: rgba(var(--bg-card), 0.3);
  border: 1px solid rgba(var(--border), 0.2);
  border-radius: 8px;
  color: rgb(var(--gray));
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
}
.s-trigger:hover {
  background: rgba(var(--bg-hover), 0.6);
  border-color: rgba(var(--accent), 0.3);
  color: rgb(var(--black));
}

/* ── Backdrop ── */
.s-backdrop {
  position: fixed;
  inset: 0;
  z-index: 8999;
  background: rgba(0, 0, 0, 0.45);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.18s ease;
}
.s-backdrop.is-open {
  pointer-events: all;
  opacity: 1;
}

/* ── Brand (mobile only, replaces back button) ── */
.s-brand {
  display: none;
  font-size: 1.1rem;
  font-weight: 700;
  color: rgb(var(--black));
  text-decoration: none;
  flex-shrink: 0;
  padding: 0 0.25rem;
  transition: color 0.2s;
}
.s-brand:hover { color: var(--accent); opacity: 1; }

/* ── Layer (fixed to viewport top, overlays the sticky header) ── */
.s-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9000;
  pointer-events: none;
  opacity: 0;
  transform: translateY(-4px);
  transition: opacity 0.18s ease, transform 0.18s ease;
}
.s-layer.is-open {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}

/* ── Bar (same padding as .nav so heights match) ── */
.s-bar {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding: 1rem 2rem;
  background: rgba(var(--gray-dark), 0.98);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(var(--border), 0.15);
}

.s-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  flex-shrink: 0;
  background: none;
  border: none;
  border-radius: 8px;
  color: rgb(var(--gray));
  cursor: pointer;
  transition: color 0.2s, background 0.2s;
}
.s-back:hover {
  color: rgb(var(--black));
  background: rgba(var(--bg-hover), 0.4);
}

/* Input wrap — this is the "search box" */
.s-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.6rem 1.1rem;
  background: rgba(var(--bg-card), 0.7);
  border: 1px solid rgba(var(--border), 0.35);
  border-radius: 10px;
  transition: border-color 0.2s, background 0.2s;
}
.s-input-wrap:focus-within {
  border-color: rgba(var(--accent), 0.6);
  background: rgba(var(--bg-card), 0.95);
}

.s-icon { color: rgb(var(--text-muted)); flex-shrink: 0; }

.s-input {
  flex: 1;
  min-width: 0;
  background: none;
  border: none;
  outline: none;
  font-size: 0.95rem;
  font-family: inherit;
  color: rgb(var(--black));
  caret-color: var(--accent);
  line-height: 1.5;
}
.s-input::placeholder { color: rgba(var(--text-muted), 0.55); }

.s-clear {
  display: none;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  background: rgba(var(--border), 0.4);
  border: none;
  border-radius: 50%;
  color: rgb(var(--text-muted));
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.s-clear:hover { background: rgba(var(--accent), 0.2); color: var(--accent); }

/* ── Dropdown (extends below header) ── */
.s-dropdown {
  overflow: hidden;
  max-height: 0;
  background: rgb(26, 26, 28);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55);
  transition: max-height 0.25s ease;
}
.s-layer.is-open .s-dropdown { max-height: 480px; }

/* ── Results ── */
.s-results {
  max-height: 400px;
  overflow-y: auto;
  overscroll-behavior: contain;
  padding: 0.375rem 0;
}
.s-results::-webkit-scrollbar { width: 4px; }
.s-results::-webkit-scrollbar-track { background: transparent; }
.s-results::-webkit-scrollbar-thumb { background: rgba(var(--border), 0.4); border-radius: 2px; }

.result-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.875rem 2rem;
  text-decoration: none;
  color: inherit;
  border-left: 2px solid transparent;
  transition: background 0.12s, border-color 0.12s;
}
.result-item:hover,
.result-item.is-active {
  background: rgba(var(--bg-hover), 0.5);
  border-left-color: var(--accent);
  opacity: 1;
}

.result-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.result-title {
  font-size: 0.9rem;
  font-weight: 600;
  color: rgb(var(--black));
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.35;
}
.result-title :global(mark) {
  background: rgba(var(--accent), 0.22);
  color: var(--accent);
  border-radius: 2px;
  padding: 0 1px;
}
.result-desc {
  font-size: 0.75rem;
  color: rgb(var(--text-muted));
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}
.result-desc :global(mark) {
  background: rgba(var(--accent), 0.14);
  color: var(--accent);
  border-radius: 2px;
}

.result-aside {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.25rem;
}
.result-chip {
  font-size: 0.58rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--accent);
  background: rgba(var(--accent), 0.1);
  border: 1px solid rgba(var(--accent), 0.2);
  border-radius: 4px;
  padding: 0.1rem 0.4rem;
  white-space: nowrap;
}
.result-chip :global(mark) { background: rgba(var(--accent), 0.28); color: inherit; }
.result-date {
  font-size: 0.63rem;
  color: rgb(var(--text-muted));
  white-space: nowrap;
}

.s-empty {
  padding: 2.5rem 2rem;
  text-align: center;
  color: rgb(var(--text-muted));
  font-size: 0.875rem;
}

/* ── Footer ── */
.s-footer {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.55rem 2rem;
  border-top: 1px solid rgba(var(--border), 0.12);
  background: rgba(0, 0, 0, 0.15);
}
.s-hint {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.62rem;
  color: rgb(var(--text-muted));
  white-space: nowrap;
}
.s-hint kbd {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 1.35em;
  padding: 0.08rem 0.3rem;
  background: rgba(var(--border), 0.35);
  border-radius: 3px;
  font-size: 0.58rem;
  font-family: inherit;
  color: rgb(var(--gray));
}
.s-count { margin-left: auto; font-size: 0.7rem; font-weight: 600; color: var(--accent); }

/* ── RWD ── */
@media (max-width: 768px) {
  .s-bar { padding: 0.875rem 1.25rem; gap: 0.75rem; }
  .result-item { padding: 0.875rem 1.25rem; }
  .s-footer { padding: 0.5rem 1.25rem; }
}
@media (max-width: 640px) {
  /* Search is inside burger menu on mobile — hide desktop trigger & layer */
  .s-trigger { display: none; }
  .s-backdrop { display: none; }
  .s-layer { display: none; }

  .result-item { padding: 0.8rem 1rem; }
  .result-desc { display: none; }
  .s-footer { padding: 0.45rem 1rem; gap: 0.5rem; }
  .s-hint { display: none; }
  .s-count { margin-left: 0; }
}
</style>
