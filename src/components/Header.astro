---
import Link from "@components/Links.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { SITE_TITLE, HeaderLinks } from "@consts";
---

<header class="site-header">
  <nav class="nav" aria-label="Global">
    <a class="brand brand-mark" href="/" aria-label={SITE_TITLE}>{SITE_TITLE}</a>

    <div class="nav-links">
      {
        HeaderLinks.map((link) => (
          <Link href={link.href}>{link.title}</Link>
        ))
      }
    </div>

    <div class="nav-actions">
      <a class="icon-btn" href="/search/" aria-label="搜尋">
        <i class="icon-[tabler--search]"></i>
      </a>
      <a
        class="icon-btn"
        href="https://github.com/osga24"
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
      >
        <i class="icon-[tabler--brand-github]"></i>
      </a>
      <ThemeToggle />
      <button class="hamburger" id="hamburger" aria-label="選單" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    {
      HeaderLinks.map((link) => (
        <Link href={link.href}>{link.title}</Link>
      ))
    }
    <Link href="/search/">搜尋</Link>
  </div>
</header>

<script>
  function bindHeader() {
    const hamburger = document.getElementById("hamburger");
    const menu = document.getElementById("mobile-menu");
    if (!hamburger || !menu || (hamburger as any)._bound) return;
    (hamburger as any)._bound = true;

    const toggle = (open?: boolean) => {
      const next = open ?? hamburger.getAttribute("aria-expanded") !== "true";
      hamburger.setAttribute("aria-expanded", String(next));
      menu.setAttribute("aria-hidden", String(!next));
      hamburger.classList.toggle("is-open", next);
      menu.classList.toggle("is-open", next);
    };

    hamburger.addEventListener("click", () => toggle());
    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => toggle(false)));
    document.addEventListener("astro:before-swap", () => toggle(false));
  }

  bindHeader();
  document.addEventListener("astro:page-load", bindHeader);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: color-mix(in srgb, rgb(var(--gray-dark)) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(var(--border), 0.15);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
  }

  .brand {
    font-size: 1.2rem;
    font-weight: 700;
    color: rgb(var(--black));
    text-decoration: none;
    transition: color 0.25s ease;
    flex-shrink: 0;
  }
  .brand:hover {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }
  .nav-links :global(a) {
    padding: 0.45rem 0.85rem;
    color: rgb(var(--gray));
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.88rem;
    font-family: var(--font-brand);
    transition: all 0.25s ease;
    white-space: nowrap;
  }
  .nav-links :global(a:hover) {
    color: rgb(var(--black));
    background: rgba(var(--bg-hover), 0.5);
  }
  .nav-links :global(a.active) {
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.12);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    color: rgb(var(--gray));
    border: 1px solid rgba(var(--border), 0.35);
    background: rgba(var(--bg-card), 0.4);
    transition: all 0.25s ease;
  }
  .icon-btn:hover {
    color: var(--accent);
    border-color: rgba(var(--accent-rgb), 0.45);
    transform: scale(1.06);
  }
  .icon-btn i {
    width: 1.05rem;
    height: 1.05rem;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.5rem;
    background: rgba(var(--bg-card), 0.4);
    border: 1px solid rgba(var(--border), 0.35);
    border-radius: 999px;
    cursor: pointer;
  }
  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: rgb(var(--gray));
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .hamburger.is-open .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.is-open .bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.25s ease;
    border-top: 1px solid rgba(var(--border), 0.15);
  }
  .mobile-menu.is-open {
    max-height: 70vh;
    opacity: 1;
  }
  .mobile-menu :global(a) {
    padding: 0.9rem 1.5rem;
    color: rgb(var(--gray));
    text-decoration: none;
    font-family: var(--font-brand);
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(var(--border), 0.1);
  }
  .mobile-menu :global(a:hover),
  .mobile-menu :global(a.active) {
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.08);
  }

  @media (max-width: 720px) {
    .nav {
      gap: 0.75rem;
      padding: 0.75rem 1rem;
    }
    .nav-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }
    .mobile-menu {
      display: flex;
    }
  }
</style>
