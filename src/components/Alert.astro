---
// Removes empty callout boxes (.info/.note/.warning/.danger/.success/.tip)
// that can be produced when authoring callouts in markdown.
---

<script>
  const ALERT_TYPES = ["info", "note", "warning", "danger", "success", "tip"];

  function isEmpty(el: Element | null) {
    if (!el) return true;
    const text = el.textContent?.trim() ?? "";
    if (text.length > 0) return false;
    const html = (el as HTMLElement).innerHTML?.trim() ?? "";
    return /^(<br\s*\/?>|<p\s*>\s*<\/p>|<div\s*>\s*<\/div>|\s)*$/i.test(html);
  }

  function cleanup() {
    ALERT_TYPES.forEach((type) => {
      document.querySelectorAll(`.article-content .${type}`).forEach((el) => {
        if (isEmpty(el)) el.remove();
      });
    });
  }

  function init() {
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", cleanup);
    } else {
      cleanup();
    }
  }

  init();
  document.addEventListener("astro:page-load", cleanup);
</script>
