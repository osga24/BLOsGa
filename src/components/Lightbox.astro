---
// Smart image lightbox — opens any .article-content / .hero-img image full screen.
// Styles live in src/styles/article.css.
---

<div id="lightbox" class="lightbox">
  <div class="lightbox-content">
    <img id="lightbox-image" class="lightbox-image" src="" alt="" />
    <div id="lightbox-caption" class="lightbox-caption"></div>
  </div>
</div>

<script>
  class SmartLightbox {
    lightbox: HTMLElement | null = null;
    lightboxImage: HTMLImageElement | null = null;
    lightboxCaption: HTMLElement | null = null;
    isInitialized = false;

    constructor() {
      this.setup();
    }

    setup() {
      this.lightbox = document.getElementById("lightbox");
      this.lightboxImage = document.getElementById("lightbox-image") as HTMLImageElement | null;
      this.lightboxCaption = document.getElementById("lightbox-caption");
      if (!this.lightbox || !this.lightboxImage) return;

      this.lightbox.style.display = "none";
      this.lightbox.classList.remove("active");
      this.bindEvents();
      this.isInitialized = true;
    }

    bindEvents() {
      this.lightbox?.addEventListener("click", (e) => {
        if (e.target === this.lightbox) this.close();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && this.lightbox?.classList.contains("active")) this.close();
      });
      this.attachImages();
    }

    attachImages() {
      const images = document.querySelectorAll<HTMLImageElement>(".article-content img, .hero-img");
      images.forEach((img) => {
        if ((img as any)._lightbox) return;
        (img as any)._lightbox = true;
        img.style.cursor = "zoom-in";
        img.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          this.open(img);
        });
      });
    }

    open(img: HTMLImageElement) {
      if (!this.isInitialized || !this.lightbox || !this.lightboxImage) return;
      const src = img.src || img.getAttribute("src") || "";
      if (!src) return;
      this.lightboxImage.src = src;
      this.lightboxImage.alt = img.alt || "";

      if (this.lightboxCaption) {
        if (img.alt && img.alt.trim()) {
          this.lightboxCaption.textContent = img.alt;
          this.lightboxCaption.style.display = "block";
        } else {
          this.lightboxCaption.style.display = "none";
        }
      }

      const detect = () => this.detectOrientation(this.lightboxImage!);
      this.lightboxImage.onload = detect;
      if (this.lightboxImage.complete && this.lightboxImage.naturalWidth > 0) detect();

      this.lightbox.style.display = "flex";
      this.lightbox.classList.add("active");
      document.body.style.overflow = "hidden";
    }

    detectOrientation(img: HTMLImageElement) {
      if (!img.naturalWidth || !img.naturalHeight) return;
      const r = img.naturalWidth / img.naturalHeight;
      let o = "square";
      if (r > 2.5) o = "ultrawide";
      else if (r < 0.4) o = "ultratall";
      else if (r > 1.3) o = "landscape";
      else if (r < 0.7) o = "portrait";
      img.setAttribute("data-orientation", o);
    }

    close() {
      if (!this.lightbox) return;
      this.lightbox.classList.remove("active");
      this.lightbox.style.display = "none";
      document.body.style.overflow = "";
      if (this.lightboxImage) {
        this.lightboxImage.src = "";
        this.lightboxImage.removeAttribute("data-orientation");
      }
    }
  }

  function initLightbox() {
    (window as any).smartLightbox = new SmartLightbox();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLightbox);
  } else {
    initLightbox();
  }
  document.addEventListener("astro:page-load", initLightbox);
</script>
